{
  "name": "Link",
  "version": "0.1.0",
  "description": "Async HTTP client library for ESP32 with bounded memory and fetch-style requests.",
  "keywords": [
    "esp32",
    "http",
    "https",
    "network",
    "fetch",
    "arduinojson",
    "link"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ZekStack/link.git"
  },
  "authors": [
    {
      "name": "zekageri",
      "maintainer": true
    }
  ],
  "license": "MIT",
  "frameworks": "arduino",
  "platforms": "espressif32",
  "dependencies": {
    "bblanchon/ArduinoJson": ">=7.0.0"
  },
  "build": {
    "srcDir": "src",
  "includeDir": "src",
    "flags": [
      "-std=gnu++20"
    ]
  }
}
